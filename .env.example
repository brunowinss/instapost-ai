# 🌐 SERVIDOR
PORT=3000
NODE_ENV=production

# 🗄️ BANCO DE DADOS (RENDER)
# Se estiver vazio, o app usará SQLite local automaticamente.
# Exemplo: postgres://user:password@host:port/dbname
DATABASE_URL=

# 🖼️ IMGBB API (UPLOAD DE IMAGENS)
# Obtenha em: https://api.imgbb.com/
IMGBB_KEY=

# 🎬 CLOUDINARY (UPLOAD DE VÍDEOS/REELS)
# Obtenha em: https://cloudinary.com/
CLOUDINARY_NAME=
CLOUDINARY_PRESET=
